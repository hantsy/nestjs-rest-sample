{
  "compilerOptions": {
    "types": ["jest", "node"],
    "module": "commonjs",
    "esModuleInterop": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "strictPropertyInitialization": false,
    "target": "es2025",
    "sourceMap": true,
    "outDir": "./dist",
    "paths": {
      "*": ["./src/*", "./types/*"]
    },
    "incremental": true,
    "ignoreDeprecations": "6.0"
  }
}
